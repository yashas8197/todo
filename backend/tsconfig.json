{
  "compilerOptions": {
    // 📁 Project structure
    "rootDir": "./src",
    "outDir": "./dist",

    // ⚙️ Node setup
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2020",
    "lib": ["ES2020"],

    // 🔄 Interop
    "esModuleInterop": true,
    "resolveJsonModule": true,

    // 🧠 Strictness
    "strict": true,

    // ⚡ Dev experience
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}